{
  "name": "helius-mcp",
  "version": "0.3.0",
  "description": "Official Helius MCP Server - Complete Solana blockchain data access for Claude",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "helius-mcp": "dist/index.js"
  },
  "scripts": {
    "prebuild": "node -p \"'export const version = \\'' + require('./package.json').version + '\\';'\" > src/version.ts",
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "helius",
    "solana",
    "blockchain",
    "mcp",
    "claude",
    "ai",
    "web3",
    "nft",
    "defi",
    "websocket",
    "laserstream"
  ],
  "author": "Helius Labs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/helius-labs/core-ai"
  },
  "homepage": "https://github.com/helius-labs/core-ai#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "bs58": "^6.0.0",
    "helius-sdk": "^2.0.5",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
